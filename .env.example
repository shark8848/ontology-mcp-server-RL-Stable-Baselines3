# Docker 部署环境变量配置
# 复制此文件为 .env 并填入实际值

# LLM 配置（必填）
OPENAI_API_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=your-api-key-here
OPENAI_MODEL=deepseek-chat
LLM_PROVIDER=deepseek

# 或使用本地 Ollama
# LLM_PROVIDER=ollama
# OLLAMA_API_URL=http://host.docker.internal:11434/v1
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_API_KEY=ollama

# 数据目录
ONTOLOGY_DATA_DIR=/app/data

# MCP Server（训练与 Agent 访问的服务地址）
MCP_BASE_URL=http://ontology-mcp-server:8000

# 可选：首次启动时初始化批量数据
INIT_BULK_DATA=false

# 可选：首次启动时生成训练语料
INIT_TRAINING_DATA=false

# 强制本地模式（1=true）：
# - 禁止 HuggingFace/Transformers 在线下载
# - LLM 仅允许本地 Ollama 端点
# - Embedding API 仅允许本地端点
FORCE_LOCAL_ONLY=0

# 构建期预下载 sentence-transformers 模型（逗号分隔）
PRELOAD_ST_MODELS=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2,sentence-transformers/all-MiniLM-L6-v2

# MCP 服务器配置（默认在 config.yaml 中启用 Owlready2，如需覆盖可取消注释）
# ONTOLOGY_USE_OWLREADY2=false

# 训练配置（可选）
# GPU 支持需要在 docker-compose.yml 中启用 deploy.resources
